# OpenClaw workflow settings
OPENCLAW_BIN=
XHS_OPENCLAW_AGENT=main
XHS_OPENCLAW_SESSION_ID=xhs-workflow
XHS_OPENCLAW_THINKING=medium

# Publisher adapter settings
XHS_PUBLISHER_ADAPTER=mock
XHS_SKILL_ROOT=
XHS_PUBLISHER_CLI=

# OpenAI image adapter settings
OPENAI_API_KEY=
XHS_IMAGE_BASE_URL=https://api.openai.com/v1
XHS_IMAGE_MODEL=gpt-image-1.5
XHS_IMAGE_SIZE=1024x1024
XHS_IMAGE_QUALITY=
XHS_IMAGE_BACKGROUND=

# Gemini image adapter settings
GEMINI_API_KEY=
XHS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
XHS_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
XHS_GEMINI_ASPECT_RATIO=3:4
XHS_GEMINI_IMAGE_SIZE=

# Optional workflow defaults
XHS_PACKS_ROOT=
